                            {
                                "box": {
                                    "code": "outlets = 2;\r\nconst featuresList = [\r\n        \"Centroid\",\r\n        \"Rolloff\",\r\n        \"Crest\",\r\n        \"Loudness_range\",\r\n        \"Amplitude\",\r\n        \"Spectral_tilt\",\r\n        \"Spectral_flux\",\r\n        \"Harmonic-to-Noise_ratio\",\r\n        \"Pitch_Salience\",\r\n        \"MFCC_5\",\r\n        \"Duration_(ms)\"  \r\n];\r\n\r\nlet d = new Dict(\"final_database\");\r\nlet e = new Dict(\"final_database_ordered\");\r\nlet resultingFeaturesArray = [];\r\n\r\n\r\n// Global operations\r\n// settind the Dict\r\ne.set(\"cols\", 0);\r\ne.set(\"features\", []);\r\ne.set(\"data\", {});\r\n\r\n\r\n\r\n\r\nfunction features_array(...n) {\r\n    let originalFeaturesArray = Array(11);\r\n    resultingFeaturesArray = [];\r\n    \r\n    originalFeaturesArray = n;\r\n    \r\n    for (let i = 0; i < originalFeaturesArray.length; i++ ) {\r\n        if (originalFeaturesArray[i] === 1) {\r\n            resultingFeaturesArray.push(featuresList[i]);\r\n        }\r\n    }\r\n}\r\n\r\n\r\n\r\n\r\n\r\nfunction bang() {\r\n    let colsOrig = d.get(\"cols\");\r\n\tlet keys = d.getkeys();\r\n\tlet dataKeys = d.get(\"data\").getkeys();\r\n\tlet data = d.get(\"data\");\r\n\tlet tempVal = [];\r\n\r\n\t\r\n\tfor (let i = 1; i < dataKeys.length + 1; i++) {\r\n\t\ttempVal = [];\r\n\t\t\r\n\t\tif (i < 10) {\r\n\t\t\ttempVal = data.get(\"sample_00\" + i);\r\n\t\t\te.set(\"data::sample_00\" + i, tempVal)\r\n\t\t} else if (i < 100) {\r\n\t\t\ttempVal = data.get(\"sample_0\" + i);\r\n\t\t\te.set(\"data::sample_0\" + i, tempVal)\r\n\t\t} else{\r\n\t\t\ttempVal = data.get(\"sample_\" + i);\r\n\t\t\te.set(\"data::sample_\" + i, tempVal)\r\n\t\t}\r\n\t}\r\n    e.set(\"cols\", colsOrig);\r\n    e.set(\"features\", resultingFeaturesArray);\r\n\toutlet(0, \"dictionary\", e.name);\r\n}\r\n\r\n",
