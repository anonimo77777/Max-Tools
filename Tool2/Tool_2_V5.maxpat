                                    "text": "v8 @embed 1",
                                    "textfile": {
                                        "text": "outlets = 2;\r\n\r\nlet featuresFlags = new Array(11);\r\nconst columnLookup = [0, 1, 2, 0, 1, 0, 0, 0, 0, 0, 0];\r\nconst datasetLookup = [\r\n                        \"temp_dataset_1\", \"temp_dataset_1\", \"temp_dataset_1\", \"temp_dataset_2\",\r\n                        \"temp_dataset_2\", \"temp_dataset_3\", \"temp_dataset_4\", \"temp_dataset_5\",\r\n                        \"temp_dataset_6_maxVal\", \"temp_dataset_7\", \"temp_dataset_8\"\r\n                        ];\r\nconst targetDateset = \"final_merging_analisys_1\";\r\n\r\n\r\n\r\nfunction parseFeatures(...n) {\r\n    featuresFlags = n;\r\n    //post('Features flags: ', featuresFlags);\r\n    \r\n }\r\n\r\nfunction datasetQuery() {\r\n     let tempString = \"\";\r\n     let selectedFeatures = 0; // The number of actually selected features\r\n     \r\n     for (let i = 0; i < featuresFlags.length; i++) {\r\n        if (featuresFlags[i]) {\r\n            selectedFeatures++;\r\n            if (selectedFeatures === 1) {\r\n                tempString = \"clear, addcolumn \" + columnLookup[i] + \", transform \" + datasetLookup[i] + \" \" + targetDateset; \r\n                outlet(0, tempString);\r\n            } else {\r\n                tempString = \"clear, addcolumn \" + columnLookup[i] + \", transformjoin \" + datasetLookup[i] + \" \" + targetDateset + \" \" + targetDateset;\r\n                outlet(0, tempString);\r\n            }\r\n         }\r\n      }\r\n      outlet(1, \"bang\"); \r\n }",
                                        "filename": "none",
                                        "flags": 0,
                                        "embed": 1,
                                        "autowatch": 1
                                    }
                                }
