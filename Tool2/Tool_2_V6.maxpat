                                        "text": "inlets = 1;\r\noutlets = 2;\r\n\r\nlet my_buf = new Buffer(\"temp_dataset_6_buffy\");\r\nlet res_buf = new Buffer(\"max_chroma_val\");\r\nlet bufChannels = my_buf.channelcount();\r\nlet bufFrames = my_buf.framecount();\r\nlet result = [];\t// array containing the index of the maximum bin\r\n\r\nfunction postBufferData(){\r\n\tbufChannels = my_buf.channelcount();\r\n\tbufFrames = my_buf.framecount();\r\n\tpost(\"The buffer  samples are: \" + bufFrames + \"\\n\");\r\n\tpost(\"The buffer  channels are: \" + bufChannels + \"\\n\");\r\n\t\r\n}\r\n\r\n// frames <-> samples; channels <-> chroma bins\r\nfunction bang() {\r\n\tlet result = [];\r\n\tbufChannels = my_buf.channelcount();\r\n\tbufFrames = my_buf.framecount();\r\n\t\r\n\t//i itera sui frames = campioni\r\n\tfor (let i = 0; i < bufFrames; i++) {\r\n\t\tlet tempArr = [];\r\n\t\t// j itera sui canali = valori di analisi\r\n\t\tfor (let j = 1; j < bufChannels + 1; j++) {\r\n\t\t\ttempArr.push(my_buf.peek(j, i, 1));\r\n\t\t}\r\n\t\tresult.push(pitchSalienceCircular(tempArr));\r\n\t}\r\n\tres_buf.poke(1, 0, result);\r\n   outlet(0, \"bang\");\r\n}\r\n\r\nfunction pitchSalienceCircular(medians) { // medians: Array(12) con valori ≥0\n  const EPS = 1e-12;\n  const sum = medians.reduce((a,b) => a + b, 0);\r\n  const mediansLength = medians.length;\r\n  const tau = 2 * Math.PI/mediansLength;\r\n  let x = 0; \r\n  let y = 0;\r\n\n  if (!(sum > 0)) return { value: NaN, valid: false }; // silenzio/zero \n  for (let k = 0; k < mediansLength; k++) {\n    const pk = medians[k] / (sum + EPS);\n    const th = tau * k;\n    x += pk * Math.cos(th);\n    y += pk * Math.sin(th);\n  }\n  const r = Math.hypot(x, y); // in [0,1]\n  return  r;\n}\n",
                                        "filename": "none",
                                        "flags": 0,
                                        "embed": 1,
                                        "autowatch": 1
                                    },
                                    "varname": "v8_AD"
                                }
